# ── Telegram ──────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram IDs of bootstrap admins
ADMIN_TELEGRAM_IDS=123456789,987654321

# Admin group chat ID (add bot to group, get ID from @userinfobot)
ADMIN_GROUP_CHAT_ID=-100123456789

# Required channel username (users must join before using bot)
REQUIRED_CHANNEL=@YourChannelUsername

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/tutoring_bot

# ── Platform Settings ─────────────────────────────────────
PLATFORM_COMMISSION_ETB=100
TUTOR_NET_RATE_ETB=250
SESSION_RATE_ETB=350
TIMEZONE=Africa/Addis_Ababa

# ── Recordings ────────────────────────────────────────────
RECORDINGS_PATH=./recordings
MAX_RECORDING_AGE_DAYS=30
MAX_RECORDING_SIZE_MB=2000
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mkv,.avi
